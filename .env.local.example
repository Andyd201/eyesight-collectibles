# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git
# ─────────────────────────────────────────────────────

# Supabase — find these in: supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role — NEVER prefix with NEXT_PUBLIC_ (server only)
# Used for admin operations like bulk inserts
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe — find at: dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# Cloudinary — for product image hosting (optional, can use Supabase Storage)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Site URL — used for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
